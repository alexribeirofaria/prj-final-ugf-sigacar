@model Categoria
<h1>@(Model.Id == 0 ? "Cadastrar categoria" : "Alterar categoria")</h1>
<form asp-action="Save" method="post" class="form-grid small">
    <div asp-validation-summary="All" class="validation"></div>
    <input asp-for="Id" type="hidden" />
    <label>Codigo <input asp-for="Codigo" /></label>
    <label>Descricao <input asp-for="Descricao" /></label>
    <label>Preco diario <input asp-for="PrecoDiario" type="number" step="0.01" /></label>
    <label>Preco semanal <input asp-for="PrecoSemanal" type="number" step="0.01" /></label>
    <label>Preco mensal <input asp-for="PrecoMensal" type="number" step="0.01" /></label>
    <label>Estoque <input asp-for="QuantidadeEstoque" type="number" /></label>
    <div class="form-actions"><button class="primary">Salvar</button><a class="button" asp-action="Index">Voltar</a></div>
</form>
